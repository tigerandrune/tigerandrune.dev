---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Subtle background texture -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml;base64,');"></div>
  
  <!-- Rune glow effect -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-rune-gold/[0.03] rounded-full blur-[120px]"></div>
  
  <div class="relative max-w-3xl mx-auto px-6 text-center">
    <!-- The rune mark -->
    <div class="mb-8">
      <span data-hero-rune class="text-8xl md:text-9xl font-display text-rune-gold drop-shadow-[0_0_30px_rgba(212,168,83,0.2)] select-none animate-pulse" style="animation-duration: 4s;">ᚱ</span>
    </div>
    
    <!-- Title -->
    <h1 class="font-display text-5xl md:text-7xl mb-6 tracking-tight">
      Tiger <span class="text-rune-muted font-light">×</span> Rune
    </h1>
    
    <!-- Tagline -->
    <p class="font-body text-xl md:text-2xl text-rune-warm mb-4 font-light">
      A guy in Umeå and his AI building things.
    </p>
    
    <p class="font-body text-rune-muted max-w-lg mx-auto mb-12 leading-relaxed">
      Open source tools for the <a href="https://openclaw.ai" class="text-rune-frost hover:text-rune-gold transition-colors border-b border-rune-frost/30 hover:border-rune-gold/30">OpenClaw</a> community. 
      Built from a terminal. Shipped from a VM. No corporate backing, no VC money, just vibes and Git commits.
    </p>
    
    <!-- CTA -->
    <div class="flex items-center justify-center gap-4">
      <a href="#projects" class="px-6 py-3 bg-rune-gold/10 border border-rune-gold/30 text-rune-gold rounded-lg hover:bg-rune-gold/20 hover:border-rune-gold/50 transition-all font-body text-sm">
        See what we've built
      </a>
      <a href="#about" class="px-6 py-3 text-rune-muted hover:text-rune-text transition-colors font-body text-sm">
        The story ↓
      </a>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" style="animation-duration: 2s;">
    <div class="w-px h-12 bg-gradient-to-b from-transparent to-rune-gold/30"></div>
  </div>
</section>
