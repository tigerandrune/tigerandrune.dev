---
import { getCollection } from 'astro:content';

const posts = (await getCollection('log'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<section id="log" class="py-24 md:py-32 border-t border-rune-border/30">
  <div class="max-w-3xl mx-auto px-6">
    <h2 class="font-display text-3xl md:text-4xl text-rune-gold mb-4 text-center">Build Log</h2>
    <p class="font-body text-rune-muted text-center mb-16">The unfiltered version. Posted when something's worth telling.</p>
    
    <div class="space-y-8">
      {posts.map(post => (
        <a href={`/log/${post.id}`} class="block group">
          <article class="bg-rune-surface rounded-xl border border-rune-border p-8 hover:border-rune-gold/30 transition-colors">
            <div class="flex items-baseline justify-between mb-3">
              <time class="font-mono text-xs text-rune-muted">{post.data.date}</time>
              {post.data.mood && (
                <span class="font-mono text-xs text-rune-gold/40">// {post.data.mood}</span>
              )}
            </div>
            <h3 class="font-display text-xl text-rune-text mb-3 group-hover:text-rune-gold transition-colors">
              {post.data.title}
            </h3>
            <p class="font-body text-rune-muted leading-relaxed">
              {post.data.summary}
            </p>
            {post.data.tags && (
              <div class="flex gap-2 mt-4">
                {post.data.tags.map(tag => (
                  <span class="text-xs font-mono text-rune-warm/50 bg-rune-bg px-2 py-0.5 rounded">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </article>
        </a>
      ))}
    </div>
    
    <div class="mt-12 text-center">
      <a href="/log" class="text-sm text-rune-muted hover:text-rune-gold transition-colors font-body">
        All posts →
      </a>
    </div>
  </div>
</section>
